#!/usr/bin/env bash
# Pre-push hook: 本地拦截会让 CI 变红的 backend 改动.
# 启用: git config core.hooksPath .githooks  (或运行 scripts/setup-hooks.sh)
# 紧急绕过: git push --no-verify

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND="$REPO_ROOT/backend"

# Pre-push 协议: stdin 每行一条待 push 的 ref:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# 推导 baseline 必须基于实际 push 的 ref, 不能假设是当前 HEAD 分支
# (否则 `git push origin foo:bar` / refspec / 多 ref push 会用错 baseline).
NULL_SHA="0000000000000000000000000000000000000000"
RUN_FULL=0
CHANGED=""

while read -r local_ref local_sha remote_ref remote_sha; do
  # 跳过删除远端分支的 push (local_sha 全 0)
  if [ "$local_sha" = "$NULL_SHA" ]; then
    continue
  fi
  # 首次 push 该 ref: 远端不存在, 跑完整检查
  if [ "$remote_sha" = "$NULL_SHA" ]; then
    RUN_FULL=1
    break
  fi
  # 累加该 ref 涉及的 backend/ 变更文件 (合集)
  ref_changed=$(git diff --name-only "$remote_sha" "$local_sha" -- backend/ 2>/dev/null || echo "")
  if [ -n "$ref_changed" ]; then
    CHANGED="$CHANGED"$'\n'"$ref_changed"
  fi
done

if [ "$RUN_FULL" -eq 0 ] && [ -z "${CHANGED//[$'\n ']/}" ]; then
  echo "[pre-push] no backend changes, skip ruff/pytest"
  exit 0
fi

cd "$BACKEND"

echo "[pre-push] ruff check..."
if ! uv run ruff check src tests; then
  echo ""
  echo "[pre-push] BLOCKED by Ruff. Fix with: cd backend && uv run ruff check src tests --fix"
  echo "[pre-push] Emergency bypass: git push --no-verify"
  exit 1
fi

echo "[pre-push] pytest (failed-first + exit-on-first-fail)..."
# -x: 第一个红就停 (快速反馈)
# --ff: 优先跑上次失败的测试 (缓存命中时通常 5-10s 内出结果)
# 首次跑或无失败历史时, 行为等同全跑 (~90s on 101 tests)
if ! uv run pytest --tb=short -q -x --ff; then
  echo ""
  echo "[pre-push] BLOCKED by failing tests."
  echo "[pre-push] Emergency bypass: git push --no-verify"
  exit 1
fi

echo "[pre-push] OK"
