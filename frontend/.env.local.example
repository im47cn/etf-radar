# 复制此文件为 .env.local 并填入真实值
# 持仓监控模块所需（不填则 /portfolio 路由功能不可用，但其它页面正常）

VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx-your-anon-key-here

# 会员订阅：爱发电订阅链接（不填则 /membership 订阅按钮显示"配置中"）
# 生产由 deploy-frontend.yml 从 GitHub Variables(vars.AFDIAN_*) 注入
VITE_AFDIAN_MONTHLY_URL=https://www.afdian.com/a/im47cn
VITE_AFDIAN_YEARLY_URL=https://www.afdian.com/a/im47cn
