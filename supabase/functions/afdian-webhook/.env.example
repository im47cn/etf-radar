# afdian-webhook Edge Function 运行时密钥（在 Supabase secrets 中配置，切勿提交真实值）
# 通过 `supabase secrets set KEY=VALUE` 注入，函数内仅以 Deno.env.get 读取。

# afdian webhook 验签 token（afdian 开发者后台获取）
AFDIAN_TOKEN=

# afdian 用户 id（afdian 开发者后台获取）
AFDIAN_USER_ID=

# 可选：若设置则仅接受该 plan_id 的订单激活会员；留空则接受该创作者全部订阅订单
AFDIAN_PLAN_ID=

# Supabase 项目 URL（形如 https://xxxx.supabase.co）
SUPABASE_URL=

# Supabase service_role key（绕过 RLS 写库，务必保密，切勿下发前端）
SUPABASE_SERVICE_ROLE_KEY=
